---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Subscribe — ${SITE_TITLE}`}
			description="Get the best hosting tips delivered to your inbox, once a month. No spam."
		/>
	</head>
	<body>
		<Header activeCategory={Astro.url.pathname} />

		<section class="hero">
			<div class="hero-inner">
				<h1>Get the best sent to your inbox, every month</h1>
				<p class="sub">
					Join our community of short-term rental hosts and get exclusive insights on
					pricing, guest experience, and growing your income — delivered straight to
					your email.
				</p>
				<div class="form-wrap">
					<input
						type="email"
						placeholder="Enter your email"
						aria-label="Email address"
					/>
					<button type="button">Subscribe</button>
				</div>
				<p class="note">Once monthly, no spam</p>
			</div>
		</section>

		<Footer />
	</body>
</html>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hero {
	background: var(--chocolate);
	padding: 6rem 2rem 7rem;
}
.hero-inner {
	max-width: 640px;
	margin: 0 auto;
	text-align: center;
}

.hero-inner h1 {
	font-size: clamp(1.9rem, 4.5vw, 3rem);
	font-weight: 700;
	line-height: 1.2;
	color: var(--cream);
	margin: 0 0 1.25rem;
}

.sub {
	font-size: 1rem;
	color: rgba(253, 248, 243, 0.65);
	line-height: 1.7;
	margin: 0 0 2.5rem;
	max-width: 480px;
	margin-left: auto;
	margin-right: auto;
}

.form-wrap {
	display: flex;
	gap: 0;
	max-width: 480px;
	margin: 0 auto 0.9rem;
}
.form-wrap input {
	flex: 1;
	padding: 0.9em 1.25em;
	font-size: 0.95rem;
	background: rgba(253, 248, 243, 0.08);
	border: 1.5px solid rgba(253, 248, 243, 0.2);
	border-right: none;
	border-radius: 4px 0 0 4px;
	color: var(--cream);
	outline: none;
	font-family: inherit;
}
.form-wrap input::placeholder { color: rgba(253, 248, 243, 0.35); }
.form-wrap input:focus { border-color: rgba(253, 248, 243, 0.5); }

.form-wrap button {
	padding: 0.9em 1.75em;
	background: var(--cream);
	color: var(--chocolate);
	border: none;
	border-radius: 0 4px 4px 0;
	font-size: 0.95rem;
	font-weight: 700;
	cursor: pointer;
	font-family: inherit;
	transition: background 0.2s, color 0.2s;
	white-space: nowrap;
}
.form-wrap button:hover {
	background: var(--primary);
	color: white;
}

.note {
	font-size: 0.78rem;
	color: rgba(253, 248, 243, 0.35);
	margin: 0;
}
</style>
