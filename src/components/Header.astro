---
import { SITE_TITLE } from '../consts';

interface Props {
	activeCategory?: string;
}

const { activeCategory = '' } = Astro.props;
const path = Astro.url.pathname;

function isActive(href: string) {
	if (href === '/') return path === '/' ? 'active' : '';
	return path === href || path.startsWith(href + '/') ? 'active' : '';
}
---

<header>
	<div class="header-inner">
		<a href="/" class="brand" aria-label={SITE_TITLE}>
			<img src="/logo.png" alt={SITE_TITLE} class="logo" />
		</a>

		<nav class="main-nav" aria-label="Main">
			<a href="/" class={isActive('/')}>Home</a>
			<a href="/about" class={isActive('/about')}>About</a>
			<a href="/subscribe" class={isActive('/subscribe')}>Subscribe</a>
			<a href="/shop" class="shop-btn">Shop</a>
			<button
				class="hamburger"
				aria-label="Open menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<span></span>
				<span></span>
				<span></span>
			</button>
		</nav>
	</div>
</header>

<!-- Mobile menu drawer -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
	<div class="mobile-menu-inner">
		<button class="close-btn" aria-label="Close menu">&times;</button>
		<nav class="mobile-nav">
			<a href="/blog/hosting-101" class={isActive('/blog/hosting-101')}>Hosting 101</a>
			<a href="/blog/guest-experience" class={isActive('/blog/guest-experience')}>Guest Experience</a>
			<a href="/blog/earnings" class={isActive('/blog/earnings')}>Earnings</a>
			<a href="/" class={`${isActive('/')} section-start`}>Home</a>
			<a href="/about" class={isActive('/about')}>About</a>
		</nav>
	</div>
</div>
<div class="mobile-overlay" id="mobile-overlay"></div>

<script>
const hamburger = document.querySelector('.hamburger') as HTMLButtonElement;
const closeBtn  = document.querySelector('.close-btn') as HTMLButtonElement;
const menu      = document.getElementById('mobile-menu')!;
const overlay   = document.getElementById('mobile-overlay')!;

function openMenu() {
	menu.classList.add('open');
	overlay.classList.add('open');
	hamburger.setAttribute('aria-expanded', 'true');
	menu.setAttribute('aria-hidden', 'false');
	document.body.style.overflow = 'hidden';
}

function closeMenu() {
	menu.classList.remove('open');
	overlay.classList.remove('open');
	hamburger.setAttribute('aria-expanded', 'false');
	menu.setAttribute('aria-hidden', 'true');
	document.body.style.overflow = '';
}

hamburger.addEventListener('click', openMenu);
closeBtn.addEventListener('click', closeMenu);
overlay.addEventListener('click', closeMenu);
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
</script>

<style>
	header {
		background: var(--background);
		border-bottom: 1px solid rgba(61, 35, 20, 0.1);
		position: relative;
		z-index: 100;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1160px;
		margin: 0 auto;
		padding: 0 2rem;
		height: 62px;
	}

	/* Logo */
	.brand { display: flex; align-items: center; }
	.logo {
		height: 36px;
		width: auto;
		display: block;
	}

	/* Main nav — right */
	.main-nav {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}
	.main-nav > a {
		font-size: 0.8rem;
		color: var(--chocolate);
		text-decoration: none;
		opacity: 0.6;
		transition: opacity 0.15s, color 0.15s;
		white-space: nowrap;
	}
	.main-nav > a:hover  { opacity: 1; color: var(--primary); }
	.main-nav > a.active { opacity: 1; font-weight: 600; }

	/* Shop CTA */
	.shop-btn {
		display: inline-block;
		padding: 0.45em 1.1em;
		background: var(--chocolate);
		color: var(--cream) !important;
		border-radius: 4px;
		font-weight: 600;
		opacity: 1 !important;
		transition: background 0.2s;
		text-decoration: none;
	}
	.shop-btn:hover { background: var(--primary) !important; color: white !important; }

	/* Hamburger */
	.hamburger {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 32px;
		height: 32px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		border-radius: 4px;
		flex-shrink: 0;
		transition: background 0.15s;
	}
	.hamburger:hover { background: rgba(61,35,20,0.06); }
	.hamburger span {
		display: block;
		width: 20px;
		height: 2px;
		background: var(--chocolate);
		border-radius: 2px;
	}

	/* Mobile drawer */
	.mobile-menu {
		position: fixed;
		top: 0;
		right: -320px;
		width: 280px;
		height: 100vh;
		background: var(--cream);
		z-index: 200;
		transition: right 0.28s ease;
		box-shadow: -4px 0 24px rgba(61,35,20,0.12);
		overflow-y: auto;
	}
	.mobile-menu.open { right: 0; }

	.mobile-menu-inner { padding: 1.5rem 1.75rem; }

	.close-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		margin-left: auto;
		width: 34px;
		height: 34px;
		background: none;
		border: none;
		font-size: 1.5rem;
		cursor: pointer;
		color: var(--chocolate);
		border-radius: 4px;
		line-height: 1;
		transition: background 0.15s;
	}
	.close-btn:hover { background: rgba(61,35,20,0.06); }

	.mobile-nav {
		display: flex;
		flex-direction: column;
		margin-top: 2rem;
	}
	.mobile-nav a {
		font-size: 1rem;
		font-weight: 500;
		color: var(--chocolate);
		text-decoration: none;
		padding: 0.85rem 0;
		border-bottom: 1px solid rgba(61,35,20,0.08);
		transition: color 0.15s;
	}
	.mobile-nav a:hover { color: var(--primary); }
	.mobile-nav a.active { font-weight: 700; }

	.mobile-nav a.section-start { margin-top: 1rem; }

	/* Overlay */
	.mobile-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(61,35,20,0.4);
		z-index: 199;
		backdrop-filter: blur(2px);
	}
	.mobile-overlay.open { display: block; }

	@media (max-width: 480px) {
		.main-nav > a:not(.shop-btn) { display: none; }
	}
</style>
